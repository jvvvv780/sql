SELECT a.nome AS aluno, p.nome AS produto
FROM compras c
JOIN alunos a ON c.id_aluno = a.id_aluno
JOIN produtos p ON c.id_produto = p.id_produto;

SELECT nome
FROM alunos
WHERE id_aluno IN (
    SELECT id_aluno
    FROM compras
    GROUP BY id_aluno
    HAVING COUNT(id_produto) > 1
);

CREATE VIEW compras_alunos AS
SELECT a.nome AS aluno, p.nome AS produto
FROM compras c
JOIN alunos a ON c.id_aluno = a.id_aluno
JOIN produtos p ON c.id_produto = p.id_produto;

CREATE INDEX idx_nome_aluno
ON alunos(nome);

